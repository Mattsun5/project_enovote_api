generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admin {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  userId    Int      @unique
  user      user     @relation(fields: [userId], references: [id])
  election election[]
  candidate  candidate[]
}

model user {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  f_name    String?
  l_name    String?
  role      String   @default("user") // "user" or "admin"
  password  String
  status    String?
  createdAt DateTime @default(now())
  admin     admin?
  refresh_token refresh_token?
  candidate  candidate?
  election_vote election_vote[]
}

model refresh_token {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  userId    Int      @unique
  user      user     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

model election {
  id         Int      @id @default(autoincrement())
  office_title      String?
  eligible_state    String?
  startAt           DateTime
  endAt             DateTime
  adminId     Int     
  admin      admin     @relation(fields: [adminId], references: [id])
  createdAt  DateTime @default(now())
  candidate  candidate[]
  election_vote election_vote[]
}

model candidate {
  id         Int      @id @default(autoincrement())
  electionId Int      
  userId    Int      @unique
  manifesto String?
  party     String?
  avatar    String?
  approvedBy  Int   
  user      user     @relation(fields: [userId], references: [id])
  election  election     @relation(fields: [electionId], references: [id])
  admin  admin     @relation(fields: [approvedBy], references: [id])
  createdAt  DateTime @default(now())
  election_vote election_vote[]
  @@unique([userId, electionId])
}

model election_vote {
  id          Int      @id @default(autoincrement())
  voteReceipt String   @unique
  userId     Int     
  electionId     Int     
  candidateId     Int     
  user      user     @relation(fields: [userId], references: [id])
  election      election     @relation(fields: [electionId], references: [id])
  candidate      candidate     @relation(fields: [candidateId], references: [id])
  createdAt  DateTime @default(now())
  @@unique([userId, electionId]) 
}